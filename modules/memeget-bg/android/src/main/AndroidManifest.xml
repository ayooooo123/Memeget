<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <!-- Keep-alive foreground service for paced background indexing. -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
  <uses-permission android:name="android.permission.WAKE_LOCK" />

  <application>
    <service
      android:name="expo.modules.memegetbg.KeepAliveService"
      android:exported="false"
      android:foregroundServiceType="dataSync" />

    <!-- Serves clipboard-staged files (videos) as content:// uris. Not exported:
         the paste target gets access through the clipboard framework's uri
         grant, which requires grantUriPermissions. -->
    <provider
      android:name="expo.modules.memegetbg.MemeClipFileProvider"
      android:authorities="${applicationId}.memegetclip"
      android:exported="false"
      android:grantUriPermissions="true">
      <meta-data
        android:name="android.support.FILE_PROVIDER_PATHS"
        android:resource="@xml/memeget_clip_paths" />
    </provider>
  </application>
</manifest>
